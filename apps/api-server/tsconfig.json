{
    "compilerOptions": {
        "module": "commonjs",
        "esModuleInterop": true,
        "isolatedModules": true,
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "esnext",
        "sourceMap": true,
        "outDir": "./dist",
        "incremental": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "forceConsistentCasingInFileNames": true,
        "noImplicitAny": false,
        "strictBindCallApply": false,
        "noFallthroughCasesInSwitch": false,
        "baseUrl": ".",
        "paths": {
            "@miao-aiflow/ai-engine": ["../../packages/ai-engine/src/index.ts"],
            "@miao-aiflow/ai-engine/*": ["../../packages/ai-engine/src/*"]
        }
    }
}
